# Database Configuration
# Provide a PostgreSQL connection string. If left blank or connection fails, the app falls back to sqlite:///edu_copilot.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edu_copilot

# LLM Providers Configuration
# Required for full LLM integration. If left blank, mock generators are used.
OPENAI_API_KEY=
COHERE_API_KEY=
GROQ_API_KEY=

# Vector Database (Qdrant) Configuration
# Leave blank to use a local, in-memory instance for testing
QDRANT_URL=
QDRANT_API_KEY=

# Application Settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
